    <?php
    // Inisialisasi variabel status dan error
    $errors = [];
    $sukses = false;
    $nama = $email = $pesan = "";

    // Memproses form jika metode yang digunakan adalah POST
    if ($_SERVER["REQUEST_METHOD"] == "POST") {
        
        // 3. Validasi Server-side: Memastikan tidak ada data yang kosong
        if (empty($_POST["nama"])) {
            $errors[] = "Nama Lengkap wajib diisi.";
        } else {
            // Mencegah XSS dengan htmlspecialchars
            $nama = htmlspecialchars(trim($_POST["nama"]));
        }

        if (empty($_POST["email"])) {
            $errors[] = "Alamat Email wajib diisi.";
        } else {
            $email = htmlspecialchars(trim($_POST["email"]));
        }

        if (empty($_POST["pesan"])) {
            $errors[] = "Pesan/Komentar wajib diisi.";
        } else {
            $pesan = htmlspecialchars(trim($_POST["pesan"]));
        }

        // Jika tidak ada error, set sukses menjadi true
        if (empty($errors)) {
            $sukses = true;
        }
    }
    ?>

    <!-- Menampilkan Pesan Error jika Validasi Gagal -->
    <?php if (!empty($errors)): ?>
        <div class="error-msg">
            <strong>Terjadi Kesalahan:</strong>
            <ul style="margin: 5px 0 0 20px; padding: 0;">
                <?php foreach ($errors as $error): ?>
                    <li><?php echo $error; ?></li>
                <?php endforeach; ?>
            </ul>
        </div>
    <?php endif; ?>

    <!-- 2. Form Input -->
    <form method="post" action="<?php echo htmlspecialchars($_SERVER["PHP_SELF"]); ?>">
        <div class="form-group">
            <label for="nama">Nama Lengkap:</label>
            <input type="text" id="nama" name="nama" value="<?php echo $nama; ?>" placeholder="Masukkan nama lengkap anda">
        </div>

        <div class="form-group">
            <label for="email">Alamat Email:</label>
            <input type="email" id="email" name="email" value="<?php echo $email; ?>" placeholder="contoh@stitek.ac.id">
        </div>

        <div class="form-group">
            <label for="pesan">Pesan / Komentar:</label>
            <textarea id="pesan" name="pesan" placeholder="Tuliskan pesan atau komentar Anda di sini..."><?php echo $pesan; ?></textarea>
        </div>

        <button type="submit">Kirim Pesan</button>
    </form>

    <!-- 3. Area Tampilan Data (Muncul setelah sukses submit) -->
    <?php if ($sukses): ?>
        <div class="result-box">
            <h3> Terima Kasih! Pesan Berhasil Terkirim</h3>
            <p><strong>Nama:</strong> <?php echo $nama; ?></p>
            <p><strong>Email:</strong> <?php echo $email; ?></p>
            <p><strong>Pesan:</strong><br><?php echo nl2br($pesan); ?></p>
        </div>
    <?php endif; ?>

